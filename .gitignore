# ══════════════════════════════════════════════════════
# ROOT .gitignore — covers backend (Python) + frontend (React/Vite)
# ══════════════════════════════════════════════════════


# ── SECRETS — NEVER COMMIT ────────────────────────────
.env
.env.*
*.env
!.env.example


# ══════════════════════════════════════════════════════
# PYTHON / BACKEND
# ══════════════════════════════════════════════════════

# Virtual environments
.venv/
venv/
env/
ENV/

# uv cache
.uv/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Type checking
.mypy_cache/
.dmypy.json

# Ruff cache
.ruff_cache/

# Temp files from ingestion
tmp/
*.pdf
*.pptx
*.docx

# Logs
logs/
*.log


# ══════════════════════════════════════════════════════
# NODE / FRONTEND
# ══════════════════════════════════════════════════════

# Dependencies
node_modules/
.npm/

# Build output
dist/
build/
.vite/
.vite-temp/

# TypeScript
*.tsbuildinfo

# Vite
vite.config.ts.timestamp-*

# Testing
coverage/


# ══════════════════════════════════════════════════════
# IDEs
# ══════════════════════════════════════════════════════

.vscode/
.idea/
*.swp
*.swo
*.suo
.project
.classpath


# ══════════════════════════════════════════════════════
# OS
# ══════════════════════════════════════════════════════

.DS_Store
Thumbs.db
desktop.ini


# ══════════════════════════════════════════════════════
# DOCKER
# ══════════════════════════════════════════════════════

# Never commit local docker overrides
docker-compose.override.yml


# ══════════════════════════════════════════════════════
# AZURE / CLOUD
# ══════════════════════════════════════════════════════

# Azure CLI session files
.azure/

# Terraform state if added later
*.tfstate
*.tfstate.backup
.terraform/